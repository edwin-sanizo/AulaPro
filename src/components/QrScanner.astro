
<div id="reader" class="w-full"></div>
<p class="text-center text-slate-500 mt-4">
  Presione "Iniciar Cámara QR" para comenzar
</p>
<div id="resultado"></div>
<button id="btnIniciar">Iniciar Cámara QR</button>

<script>
  import { Html5QrcodeScanner } from 'html5-qrcode';
  
  let html5QrcodeScanner: Html5QrcodeScanner | null = null;

  function onScanSuccess(decodedText: string) {
    const resultado = document.getElementById('resultado') as HTMLDivElement;
    resultado.innerHTML = `✅ QR Detectado: <b>${decodedText}</b>`;
    
    if (html5QrcodeScanner) {
      html5QrcodeScanner.pause();
      setTimeout(() => html5QrcodeScanner?.resume(), 3000);
    }
  }

  function onScanFailure(error: string) {}

  document.getElementById('btnIniciar')?.addEventListener('click', () => {
    if (html5QrcodeScanner) html5QrcodeScanner.clear();

    html5QrcodeScanner = new Html5QrcodeScanner(
      "reader",
      { fps: 10, qrbox: { width: 250, height: 250 } },
      false
    );
    html5QrcodeScanner.render(onScanSuccess, onScanFailure);
    document.getElementById('resultado')!.textContent = 'Apunta al QR del alumno...';
  });
</script>

<style>
  #reader { width: 100%; max-width: 400px; border: 3px solid #1E3A8A; border-radius: 10px; overflow: hidden; min-height: 300px; }
  #resultado { margin-top: 20px; padding: 15px; background: white; border-radius: 8px; font-size: 18px; color: #1E3A8A; font-weight: bold; }
  button { margin-top: 15px; padding: 12px 25px; background: #10B981; color: white; border: none; border-radius: 8px; font-size: 16px; cursor: pointer; }
</style>

