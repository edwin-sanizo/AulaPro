---
import { supabase } from "../lib/supabase";
---

<div
  id="reader"
  class="w-full max-w-sm mx-auto border-2 border-blue-800 rounded-xl overflow-hidden"
>
</div>

<div
  id="resultado"
  class="mt-4 p-4 bg-slate-100 rounded-lg text-center font-semibold"
>
  Iniciando Cámara...
</div>

<script>
  import { Html5Qrcode } from "html5-qrcode";
  import { supabase } from "../lib/supabase";

  import {getLocalDate} from '../libr/fechas';

  // let ultimoCodigo: string | null = null;
  let puedeEscanear = true;
  let html5QrCode: Html5Qrcode;
  // const codigosEscaneados = new Set<string>();

  (window as any).asistenciaCerrada =
  localStorage.getItem("asistenciaCerrada") === "true";

  async function iniciarCamara() {
    if ((window as any).asistenciaCerrada) {
      const reader = document.getElementById("reader");
      if (reader) {
        reader.style.display = "none";
      }

      const resultado = document.getElementById("resultado");
      if (resultado) {
        resultado.innerHTML = "✅ Asistencia cerrada";
      }
      return;
    }

    const resultado = document.getElementById(
      "resultado",
    ) as HTMLDivElement | null;

    try {
      html5QrCode = new Html5Qrcode("reader");

      await html5QrCode.start(
        { facingMode: "environment" },
        {
          fps: 10,
          qrbox: {
            width: 250,
            height: 250,
          },
        },
        async (decodedText: string) => {
          if((window as any).asistenciaCerrada) return;

          if (!puedeEscanear) return;

          puedeEscanear = false;

          // Verificar si ya fue escaneado
          // if (codigosEscaneados.has(decodedText)) {
          //   const resultado = document.getElementById(
          //     "resultado",
          //   ) as HTMLDivElement;

          //   resultado.innerHTML = `
          //     <div class="text-amber-600 font-bold">
          //       ⚠ Alumno ya registrado
          //     </div>
          //     <div>${decodedText}</div>
          //   `;

          //   setTimeout(() => {
          //     puedeEscanear = true;
          //   }, 2000);

          //   return;
          // }

          // Guardar QR como registrado
          // codigosEscaneados.add(decodedText);

          const studentCodigo = decodedText;

          // Verificamos que el código QR sea de un estudiante y no cualquier otro
          const { data: studentData, error: errorStudent } = await supabase
            .from("students")
            .select("nombre_completo")
            .eq("codigo", studentCodigo)
            .single();

          if (errorStudent || !studentData) {
            const resultado = document.getElementById("resultado");

            if (resultado) {
              resultado.innerHTML = `
              <div class="text-red-600 font-bold">
                ❌ Código inválido
              </div>
              <div>${studentCodigo}</div>
            `;
            }

            setTimeout(() => {
              puedeEscanear = true;
            }, 2000);

            return;
          }

          const { data: student } = await supabase
            .from("students")
            .select("nombre_completo")
            .eq("codigo", studentCodigo)
            .single();

          const nombre = student?.nombre_completo || studentCodigo;

          const hoy = getLocalDate();

          const { data: existente } = await supabase
            .from("attendance")
            .select("id")
            .eq("student_codigo", studentCodigo)
            .eq("fecha_dia", hoy)
            .maybeSingle();

          if (existente) {
            const resultado = document.getElementById("resultado");

            if (resultado) {
              resultado.innerHTML = `
                <div class="text-amber-600 font-bold">
                  ⚠ Ya registrado hoy
                </div>
                <div>${studentCodigo}</div>
              `;
            }

            setTimeout(() => {
              puedeEscanear = true;
            }, 2000);

            return;
          }

          const { error } = await supabase.from("attendance").insert([
            {
              student_codigo: studentCodigo,
              fecha_dia: hoy,
              estado: "Presente",
            },
          ]);
          if (error) {
            console.log("Error guardando asistencia");
            return;
          }
          // Incrementar contador
          await actualizarContador();

          // Actualizar último alumno
          const titulo = document.getElementById("tituloUltimoAlumno");

          const ultimoAlumno = document.getElementById("ultimoAlumno");

          if (titulo && ultimoAlumno) {
            titulo.classList.remove("hidden");
            ultimoAlumno.textContent = nombre;
          }

          // Cambio de Esperando QR a Asistencia registrada
          const estado = document.getElementById("estado");

          if (estado) {
            estado.textContent = "✅ Asistencia registrada";
          }

          // // Evitar múltiples lecturas del mismo QR
          // if (decodedText === ultimoCodigo) return;

          // ultimoCodigo = decodedText;

          setTimeout(() => {
            puedeEscanear = true;

            const estado = document.getElementById("estado");
            if (estado) {
              estado.textContent = "📷 Esperando QR...";
            }
          }, 2000);

          if (resultado) {
            resultado.innerHTML = `
              <div class="text-green-600">
                ✅ Alumno detectado
              </div>

              <div class="mt-2 text-lg">
                ${nombre}
              </div>
            `;
          }
          // Aquí luego consultaremos Supabase
        },
        () => {
          // Ignorar errores de lectura
        },
      );

      if (resultado) {
        resultado.innerHTML = "📷 Cámara iniciada. Apunte al código QR.";
      }
    } catch (error) {
      console.error(error);

      if (resultado) {
        resultado.innerHTML = `
          <div class="text-red-600">
            ❌ No se pudo acceder a la cámara
          </div>
        `;
      }
    }
  }

  async function actualizarContador() {
    const hoy = getLocalDate();

    const { count } = await supabase
      .from("attendance")
      .select("*", { count: "exact", head: true })
      .eq("fecha_dia", hoy);

    const contador = document.getElementById("contador");

    if (contador) {
      contador.textContent = `Asistentes: ${count || 0}`;
    }
  }

  const btnFinalizar = document.getElementById("btnFinalizar");

  btnFinalizar?.addEventListener("click", async () => {
    try {
      await html5QrCode.stop();
      await html5QrCode.clear();

      const reader = document.getElementById("reader");
      if (reader) {
        reader.innerHTML = "";
        reader.style.display = "none";
      }

      const hoy = getLocalDate();

      // Total estudiantes
      const { data: students } = await supabase
        .from("students")
        .select("codigo, nombre_completo")
        .order("nombre_completo");

      // Asistencia de hoy
      const { data: asistenciaHoy } = await supabase
        .from("attendance")
        .select("student_codigo, estado")
        .eq("fecha_dia", hoy);

      const presentes =
        asistenciaHoy?.filter((a) => a.estado === "Presente").length || 0;

      const retrasos =
        asistenciaHoy?.filter((a) => a.estado === "Retraso").length || 0;

      const licencias =
        asistenciaHoy?.filter((a) => a.estado === "Licencia").length || 0;
      
      // Calcular ausentes
      const codigosRegistrados = new Set(
        asistenciaHoy?.map((a) => a.student_codigo) || [],
      );

      const ausentes =
        students?.filter(
          (s) => !codigosRegistrados.has(s.codigo),
        ) || [];

      const panelResumen = document.getElementById("panelResumen");
      const contenidoResumen = document.getElementById("contenidoResumen");

      if (panelResumen && contenidoResumen) {
        contenidoResumen.innerHTML = `
          <h3 class="text-xl font-bold mb-4">
            📋 Resumen de Asistencia
          </h3>

          <div>✅ Presentes: ${presentes}</div>
          <div>🟡 Retrasos: ${retrasos}</div>
          <div>🔵 Licencias: ${licencias}</div>
          <div>❌ Ausentes: ${ausentes.length}</div>

          <div class="mt-4">
            <div class="font-semibold">
              Ausentes:
            </div>

            ${
              ausentes.length
                ? ausentes
                    .map((a) => `<div>• ${a.nombre_completo}</div>`)
                    .join("")
                : "<div>Ninguno</div>"
            }
          </div>
        `;

        panelResumen.classList.remove("hidden");
      }

      const panelUltimoAlumno = document.getElementById("panelUltimoAlumno");

      if (panelUltimoAlumno) {
        panelUltimoAlumno.style.display = "none";
      }

      const estado = document.getElementById("estado");

      if (estado) {
        estado.style.display = "none";
      }

      const resultado = document.getElementById("resultado");

      if (resultado) {
        resultado.innerHTML = `
          <div class="text-green-600 font-bold text-xl">
            ✅ Asistencia finalizada correctamente
          </div>
        `;
      }
    } catch (error) {
      console.error(error);
    }
  });

  iniciarCamara();
  actualizarContador();
</script>

<style>
  #reader {
    min-height: 300px;
  }
</style>
