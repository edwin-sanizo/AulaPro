---
// src/components/QrScannerV2.astro
const { sessionId } = Astro.props;
---

<div id="qr-scanner-container" data-session-id={sessionId}>
  <!-- ✅ qr-scanner usa un elemento <video> -->
  <video
    id="qr-video"
    class="w-full max-w-sm mx-auto border-2 border-blue-800 rounded-xl overflow-hidden bg-black"
    playsinline
    autoplay
  ></video>

  <div
    id="resultado"
    class="mt-4 p-4 bg-slate-100 rounded-lg text-center font-semibold"
  >
    📷 Iniciando Cámara...
  </div>
</div>

<script>
  // ✅ Importar qr-scanner (solo en cliente)
  import QrScanner from 'qr-scanner';
  import type QrScannerType from 'qr-scanner'; // ✅ Importar el tipo
  import { supabase } from '../lib/supabase-client';

  const container = document.getElementById('qr-scanner-container');
  const sessionId = container?.dataset.sessionId;

  let puedeEscanear = true;
  let qrScanner: QrScannerType | null = null;
  let scanTimeout = null;
  let currentCourseId: any = null;

  // ✅ AGREGAR ESTA FUNCIÓN COMPLETA
  async function getCurrentCourseId() {
    if (currentCourseId) return currentCourseId;
    
    try {
      const { data: sesion } = await supabase
        .from('v2_attendance_sessions')
        .select('teacher_assignment_id')
        .eq('id', sessionId)
        .single();

      if (!sesion) return null;

      const { data: asignacion } = await supabase
        .from('v2_teacher_assignments')
        .select('course_id')
        .eq('id', sesion.teacher_assignment_id)
        .single();

      currentCourseId = asignacion?.course_id || null;
      return currentCourseId;
    } catch (error) {
      console.error('Error obteniendo course_id:', error);
      return null;
    }
  }

  // ✅ Función para actualizar el contador
  async function actualizarContador() {
    try {
      if (!sessionId) return;

      const { data } = await supabase
        .from('v2_attendance')
        .select('status')
        .eq('session_id', sessionId);

      const asistentes =
        data?.filter((a) => a.status === 'Presente' || a.status === 'Retraso')
          .length || 0;

      const contador = document.getElementById('contador');
      if (contador) {
        contador.textContent = `👥 Asistentes: ${asistentes}`;
      }
    } catch (error) {
      console.error('Error actualizando contador:', error);
    }
  }

  // ✅ Función para guardar asistencia
  async function guardarAsistencia(studentId: string, studentName: string, estadoSeleccionado: string) {
    try {
      const { error } = await supabase
        .from("v2_attendance")
        .insert([
          {
            session_id: sessionId,
            student_id: studentId,
            status: estadoSeleccionado,
          },
        ]);

      if (error) {
        console.error('❌ Error guardando asistencia');
        return;
      }

      await actualizarContador();

      const titulo = document.getElementById('tituloUltimoAlumno');
      const ultimoAlumno = document.getElementById('ultimoAlumno');

      if (titulo && ultimoAlumno) {
        titulo.classList.remove('hidden');
        ultimoAlumno.textContent = studentName;
      }

      document.dispatchEvent(
        new CustomEvent('qr-scanned', {
          detail: { studentName },
        })
      );

      const resultado = document.getElementById('resultado');
      if (resultado) {
        resultado.innerHTML = `
          <div class="text-green-600 font-bold">✅ ${estadoSeleccionado}</div>
          <div class="mt-2 text-lg">${studentName}</div>
        `;
      }

      setTimeout(() => {
        puedeEscanear = true;
        const estado = document.getElementById('estado');
        if (estado) estado.textContent = '📷 Esperando QR...';
        if (resultado) {
          resultado.innerHTML = '📷 Cámara iniciada. Apunte al código QR.';
        }
      }, 2000);
    } catch (error) {
      console.error('❌ Error al guardar asistencia:', error);
    }
  }

  // ✅ Iniciar cámara con qr-scanner
  async function iniciarCamara() {
    const video = document.getElementById('qr-video') as HTMLVideoElement;
    const resultado = document.getElementById('resultado') as HTMLDivElement | null;

    if (!sessionId) {
      if (resultado) {
        resultado.innerHTML = `<div class="text-red-600 font-bold">❌ No hay sesión activa</div>`;
      }
      return;
    }

    try {
      // ✅ Verificar que el elemento video existe
      if (!video) {
        throw new Error('No se encontró el elemento video');
      }

      // ✅ Crear el scanner
      qrScanner = new QrScanner(
        video,
        async (result) => {
          // ✅ Escaneo exitoso
          if (!puedeEscanear) return;
          puedeEscanear = false;

          const studentCodigo = result.data;

          // ✅ Verificar que el código QR sea de un estudiante
          const { data: student, error: errorStudent } = await supabase
            .from('v2_students')
            .select('id, first_name, last_name, course_id')
            .eq('code', studentCodigo)
            .single();

          if (errorStudent || !student) {
            if (resultado) {
              resultado.innerHTML = `
                <div class="text-red-600 font-bold">❌ Código inválido</div>
                <div>${studentCodigo}</div>
              `;
            }
            setTimeout(() => {
              puedeEscanear = true;
            }, 2000);
            return;
          }

          // ✅ NUEVA VALIDACIÓN: Verificar que el estudiante pertenezca al curso
          const courseId = await getCurrentCourseId();

          if (courseId && student.course_id !== courseId) {
            if (resultado) {
              resultado.innerHTML = `
                <div class="text-red-600 font-bold">❌ Estudiante no pertenece a este curso</div>
                <div class="text-sm text-gray-500 mt-2">${student.first_name} ${student.last_name}</div>
                <div class="text-xs text-gray-400">Código: ${studentCodigo}</div>
              `;
            }
            setTimeout(() => {
              puedeEscanear = true;
            }, 3000);
            return;
          }

          const nombre = `${student.first_name} ${student.last_name}`;
          const studentId = student.id;

          // ✅ Verificar si ya fue registrado hoy
          const { data: existente } = await supabase
            .from('v2_attendance')
            .select('id')
            .eq('session_id', sessionId)
            .eq('student_id', studentId)
            .maybeSingle();

          if (existente) {
            if (resultado) {
              resultado.innerHTML = `
                <div class="text-amber-600 font-bold">⚠️ Ya registrado hoy</div>
                <div>${nombre}</div>
              `;
            }
            setTimeout(() => {
              puedeEscanear = true;
            }, 2000);
            return;
          }

          const estado = document.getElementById('estado');
          if (estado) {
            estado.textContent = '👤 Estudiante detectado';
          }

          if (resultado) {
            resultado.innerHTML = `
              <div class="text-green-600 font-bold">✅ Estudiante detectado</div>
              <div class="mt-2 text-lg">${nombre}</div>
              <div class="flex gap-2 justify-center mt-4">
                <button
                  id="btnPresente"
                  class="bg-green-600 text-white px-4 py-2 rounded-lg hover:bg-green-700 transition-colors"
                >
                  Presente
                </button>
                <button
                  id="btnRetraso"
                  class="bg-yellow-500 text-white px-4 py-2 rounded-lg hover:bg-yellow-600 transition-colors"
                >
                  Retraso
                </button>
              </div>
            `;

            const btnPresente = document.getElementById('btnPresente');
            const btnRetraso = document.getElementById('btnRetraso');

            btnPresente?.addEventListener('click', () => {
              guardarAsistencia(studentId, nombre, 'Presente');
            });

            btnRetraso?.addEventListener('click', () => {
              guardarAsistencia(studentId, nombre, 'Retraso');
            });
          }
        },
        {
          // ✅ Configuración del scanner
          maxScansPerSecond: 5,
          highlightScanRegion: true,
          highlightCodeOutline: true,
          preferredCamera: 'environment',
          returnDetailedScanResult: true,
        }
      );

      // ✅ Iniciar el scanner
      await qrScanner.start();

      if (resultado) {
        resultado.innerHTML = '📷 Cámara iniciada. Apunte al código QR.';
      }

    } catch (error) {
      console.error('❌ Error al iniciar cámara:', error);
      if (resultado) {
        const errorMessage = error instanceof Error ? error.message : 'Error desconocido';
        resultado.innerHTML = `
          <div class="text-red-600 font-bold">❌ No se pudo acceder a la cámara</div>
          <div class="text-sm text-gray-500 mt-2">${errorMessage || ''}</div>
          <button
            id="btnReintentar"
            class="mt-4 bg-blue-600 text-white px-4 py-2 rounded-lg hover:bg-blue-700 transition-colors"
          >
            🔄 Reintentar
          </button>
        `;
        document.getElementById('btnReintentar')?.addEventListener('click', () => {
          // ✅ Reiniciar el scanner
          if (qrScanner) {
            qrScanner.destroy();
            qrScanner = null;
          }
          setTimeout(iniciarCamara, 500);
        });
      }
    }
  }

  // ✅ Evento: Finalizar asistencia (desde escanear_v2.astro)
  document.addEventListener('finalizar-asistencia', async (event: Event) => {
    const customEvent = event as CustomEvent;
    const { sessionId: sessionIdFromEvent } = customEvent.detail || {};

    try {
      const customEvent = event as CustomEvent;
      const { sessionId: sessionIdFromEvent } = customEvent.detail || {};
      // ✅ Detener y destruir el scanner
      if (qrScanner) {
        qrScanner.destroy();
        qrScanner = null;
      }

      const video = document.getElementById('qr-video');
      if (video) {
        video.style.display = 'none';
      }

      const sessionIdToUse = sessionIdFromEvent || sessionId;

      if (!sessionIdToUse) {
        console.error('❌ No hay sessionId para finalizar');
        return;
      }

      // ✅ Obtener el teacherAssignmentId desde la sesión
      const { data: sesion, error: sessionError } = await supabase
        .from('v2_attendance_sessions')
        .select('teacher_assignment_id')
        .eq('id', sessionIdToUse)
        .single();

      if (sessionError) {
        console.error('❌ Error al obtener la sesión: ', sessionError);
        return;
      }

      if(!sesion) {
        console.error('❌ No se encontró la sesión');
        return;
      }

      const teacherAssignmentId = sesion.teacher_assignment_id;

      // ✅ Obtener el course_id de la asignación
      const { data: asignacion, error: asignacionError } = await supabase
        .from('v2_teacher_assignments')
        .select('course_id')
        .eq('id', teacherAssignmentId)
        .single();

      if (asignacionError) {
        console.error('❌ Error al obtener asignación:', asignacionError);
        return;
      }

      if (!asignacion) {
        console.error('❌ No se encontró la asignación');
        return;
      }

      // ✅ Obtener SOLO los estudiantes del curso
      const { data: students, error: studentsError } = await supabase
        .from('v2_students')
        .select('id, code, first_name, last_name')
        .eq('course_id', asignacion.course_id)
        .order('last_name');

      if (studentsError) {
        console.error('❌ Error al obtener estudiantes:', studentsError);
        return;
      }

      // ✅ Obtener asistencias de la sesión
      const { data: asistenciaHoy, error: asistenciaError } = await supabase
        .from('v2_attendance')
        .select('student_id, status')
        .eq('session_id', sessionIdToUse);

      if (asistenciaError) {
        console.error('❌ Error al obtener asistencias:', asistenciaError);
        return;
      }

      const presentes =
        asistenciaHoy?.filter((a) => a.status === 'Presente').length || 0;

      const retrasos =
        asistenciaHoy?.filter((a) => a.status === 'Retraso').length || 0;

      const licencias =
        asistenciaHoy?.filter((a) => a.status === 'Licencia').length || 0;

      const estudiantesRegistrados = new Set(
        asistenciaHoy?.map((a) => a.student_id) || []
      );

      const asistentes = presentes + retrasos;
      const ausentes =
        students?.filter((s) => !estudiantesRegistrados.has(s.id)) || [];

      // ✅ Mostrar resumen
      const panelResumen = document.getElementById('panelResumen');
      const contenidoResumen = document.getElementById('contenidoResumen');

      if (panelResumen && contenidoResumen) {
        contenidoResumen.innerHTML = `
          <h3 class="text-xl font-bold mb-4">📋 Resumen de Asistencia</h3>
          <div>👥 Asistentes: ${asistentes}</div>
          <div>✅ Presentes: ${presentes}</div>
          <div>🟡 Retrasos: ${retrasos}</div>
          <div>🔵 Licencias: ${licencias}</div>
          <div>❌ Ausentes: ${ausentes.length}</div>
          <div class="mt-4">
            <div class="font-semibold">Ausentes:</div>
            ${
              ausentes.length
                ? ausentes
                    .map((a) => `<div>• ${a.first_name} ${a.last_name}</div>`)
                    .join('')
                : '<div>Ninguno</div>'
            }
          </div>
        `;
        panelResumen.classList.remove('hidden');
      } else {
        console.error('❌ No se encontraron panelResumen o contenidoResumen');
      }

      // ✅ Ocultar elementos
      const panelUltimoAlumno = document.getElementById('panelUltimoAlumno');
      const estado = document.getElementById('estado');
      const btnAsistenciaManual = document.getElementById('btnAsistenciaManual');
      const contador = document.getElementById('contador');
      const btnFinalizar = document.getElementById('btnFinalizar');

      if (panelUltimoAlumno) panelUltimoAlumno.style.display = 'none';
      if (estado) estado.style.display = 'none';
      if (btnAsistenciaManual) btnAsistenciaManual.style.display = 'none';
      if (contador) contador.style.display = 'none';
      if (btnFinalizar) btnFinalizar.style.display = 'none';

      const resultado = document.getElementById('resultado');
      if (resultado) {
        resultado.innerHTML = `
          <div class="text-green-600 font-bold text-xl">
            ✅ Asistencia finalizada correctamente
          </div>
        `;
      }
    } catch (error) {
      console.error('❌ Error al finalizar asistencia:', error);
    }
  });

  // ✅ Iniciar cámara y contador
  iniciarCamara();
  actualizarContador();

  // ✅ Actualizar contador cada 10 segundos
  setInterval(actualizarContador, 10000);

  // ✅ Limpiar el scanner al cerrar la página
  window.addEventListener('beforeunload', () => {
    if (qrScanner) {
      qrScanner.destroy();
      qrScanner = null;
    }
  });
</script>

<style>
  #qr-video {
    min-height: 250px;
    background: #000;
    border-radius: 12px;
    overflow: hidden;
  }

  /* ✅ El video ocupa todo el contenedor */
  #qr-video {
    width: 100% !important;
    height: 100% !important;
    object-fit: cover;
    display: block;
  }
</style>