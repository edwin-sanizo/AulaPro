---
import "../styles/global.css";

const { title } = Astro.props;
---

<!doctype html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width" />
  <title>{title}</title>
</head>

<body class="bg-slate-100 min-h-screen p-8">
  <slot />
</body>

</html>