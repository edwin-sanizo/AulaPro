---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import HeroCard from "../components/HeroCard.astro";
import Button from "../components/Button.astro";
---

<Layout title="AulaPro">
    <Header />

    <div class="mt-6">
        <HeroCard />
    </div>

    <div class="mt-6">
        <Button href="/escanear" text="Llamar Lista" />
    </div>

    <div class="mt-6">
        <Button href="/revision" text="Revisar Tareas" />
    </div>

    <div class="mt-6">
        <a
            href="/seleccion"
            class="block w-full text-center bg-slate-600 hover:bg-slate-700 text-white py-3 rounded-xl"
        >
            Volver
        </a>
    </div>
</Layout>
