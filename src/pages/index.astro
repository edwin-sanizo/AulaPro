---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import HeroCard from "../components/HeroCard.astro";
import Button from "../components/Button.astro";
---

<Layout title="AulaPro">
	<Header />

	<div class="mt-6">
		<HeroCard />
	</div>

	<div class="mt-6">
		<Button
			href="/escanear"
			text="Llamar Lista"
		/>
	</div>

	<div class="mt-6">
		<Button
			href="/revision"
			text="Revisar Tarea"
		/>
	</div>
</Layout>