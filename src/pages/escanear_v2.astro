---
import Layout from "../layouts/Layout.astro";
import HeaderMinimal from "../components/HeaderMinimal.astro";
import QrScannerV2 from "../components/QrScannerV2.astro";
import { createClient } from "../lib/supabase";
import { formatearFechaBolivia } from "../libr/fechas";

// 1️⃣ Obtener usuario del middleware
const user = Astro.locals.user;

// 2️⃣ Crear cliente para consultas en servidor
const supabase = createClient({
  request: Astro.request,
  cookies: Astro.cookies,
});

// 3️⃣ Obtener sessionId desde la URL
const url = new URL(Astro.url);
const sessionId = url.searchParams.get("sessionId");

// 4️⃣ Si no hay sessionId, redirigir a gestión
if (!sessionId) {
  return Astro.redirect("/gestion_v2?error=sin-sesion");
}

const { data: profesor } = await supabase
  .from("v2_teachers")
  .select("id")
  .eq("auth_user_id", user?.id)
  .single();

// 5️⃣ Obtener datos de la sesión (desde el servidor)
const { data: sesion } = await supabase
  .from("v2_attendance_sessions")
  .select(
    `
    id,
    status,
    session_date,
    teacher_assignment_id,
    v2_teacher_assignments (
      id,
      teacher_id,
      v2_courses (level, parallel),
      v2_subjects (name)
    )
  `,
  )
  .eq("id", sessionId)
  .single();

const asignacion = sesion?.v2_teacher_assignments as any;

// 6️⃣ Si no existe la sesión, redirigir
if (!sesion || asignacion?.teacher_id !== profesor?.id) {
  return Astro.redirect("/gestion_v2?error=sesion-no-encontrada");
}

// 7️⃣ Si la sesión está cerrada, redirigir
if (sesion.status === "closed") {
  return Astro.redirect("/gestion_v2?error=sesion-cerrada");
}

// 8️⃣ Extraer datos para mostrar
// const asignacion = sesion.v2_teacher_assignments as any;
const course = asignacion?.v2_courses || {};
const subject = asignacion?.v2_subjects || {};

const subjectName = subject?.name || "Sin materia";
const courseName =
  `${course?.level || ""} ${course?.parallel || ""}`.trim() || "Sin curso";
const sessionDate = sesion.session_date || "";
const fechaBolivia = formatearFechaBolivia(sessionDate);

// 9️⃣ Obtener conteo de asistentes (desde el servidor)
const { count: asistentesCount } = await supabase
  .from("v2_attendance")
  .select("*", { count: "exact", head: true })
  .eq("session_id", sessionId)
  .in("status", ["Presente", "Retraso"]);

// 🔟 Obtener último estudiante escaneado (desde el servidor)
const { data: ultimoAsistente } = await supabase
  .from("v2_attendance")
  .select(
    `
    id,
    created_at,
    v2_students (
      first_name,
      last_name,
      code
    )
  `,
  )
  .eq("session_id", sessionId)
  .eq("status", "Presente")
  .order("created_at", { ascending: false })
  .limit(1)
  .single();

const ultimoEstudiante = (ultimoAsistente?.v2_students as any) || null;
const nombreUltimo = ultimoEstudiante
  ? `${ultimoEstudiante.first_name || ""} ${ultimoEstudiante.last_name || ""}`.trim()
  : null;
---

<Layout title="Control de Asistencia">
  <HeaderMinimal />

  <div class="max-w-2xl mx-auto p-6">
    <div class="mt-6 text-center">
      <h2 class="text-2xl font-bold">Control de Asistencia</h2>
      <p class="text-gray-500">{subjectName} - {courseName}</p>
      <p class="text-sm text-gray-400">{fechaBolivia}</p>

      <!-- ✅ Contador (desde el servidor) -->
      <div id="contador" class="text-center font-semibold text-lg mt-4">
        👥 Asistentes: {asistentesCount || 0}
      </div>
    </div>

    <div class="mt-6">
      <!-- ✅ Pasar sessionId como prop -->
      <QrScannerV2 sessionId={sessionId} />

      <div id="estado" class="mt-4 text-center">📷 Esperando QR...</div>

      <!-- Panel Resumen (oculto inicialmente) -->
      <div id="panelResumen" class="hidden mt-6 p-4 bg-slate-100 rounded-xl">
        <div id="contenidoResumen"></div>
        <button
          id="btnConfirmarResumen"
          class="w-full mt-4 bg-green-600 text-white py-3 rounded-xl cursor-pointer"
        >
          Confirmar
        </button>
      </div>

      <!-- ✅ Último estudiante (desde el servidor) -->
      <div
        id="panelUltimoAlumno"
        class="mt-4 p-4 bg-slate-100 rounded-lg text-center"
      >
        <div id="tituloUltimoAlumno" class="font-semibold">
          Último estudiante escaneado
        </div>
        <div id="ultimoAlumno">
          {nombreUltimo || "Ningún estudiante escaneado"}
        </div>
      </div>

      <!-- ✅ Botón Asistencia Manual con sessionId -->
      <a
        id="btnAsistenciaManual"
        href={`/asistencia_manual_v2?sessionId=${sessionId}`}
        class="block w-full text-center bg-blue-600 hover:bg-blue-700 text-white font-semibold py-3 rounded-xl transition"
      >
        ✏️ Asistencia manual
      </a>

      <!-- ✅ Botón Finalizar -->
      <button
        id="btnFinalizar"
        class="w-full mt-6 bg-red-600 hover:bg-red-700 text-white py-3 rounded-xl cursor-pointer"
      >
        🔒 Finalizar Asistencia
      </button>

      <!-- ✅ Volver con teacher_assignment_id -->
      <div class="mt-6">
        <a
          href={`/gestion_v2?id=${sesion.teacher_assignment_id}`}
          class="block w-full text-center bg-slate-600 hover:bg-slate-700 text-white py-3 rounded-xl"
        >
          ← Volver
        </a>
      </div>
    </div>
  </div>
</Layout>

<script>
  // ✅ Solo lógica de UI (event listeners)
  import { supabase } from "../lib/supabase-client";
  import { toast } from "sonner";

  const sessionId = new URLSearchParams(window.location.search).get(
    "sessionId",
  );
  const btnFinalizar = document.getElementById("btnFinalizar");
  const btnConfirmarResumen = document.getElementById("btnConfirmarResumen") as HTMLButtonElement | null;


    // ✅ Click en "Finalizar Asistencia"
  btnFinalizar?.addEventListener("click", () => {
    // ✅ Ocultar botones ANTES de disparar el evento
    const btnAsistenciaManual = document.getElementById(
      "btnAsistenciaManual",
    );
    const contador = document.getElementById("contador");
    const estado = document.getElementById("estado");
    const panelUltimoAlumno = document.getElementById("panelUltimoAlumno");

    if (btnAsistenciaManual) btnAsistenciaManual.style.display = "none";
    if (contador) contador.style.display = "none";
    if (estado) estado.style.display = "none";
    if (panelUltimoAlumno) panelUltimoAlumno.style.display = "none";

    // ✅ Deshabilitar el botón Finalizar
    const btnFinalizar = document.getElementById("btnFinalizar") as HTMLButtonElement | null;
    if (btnFinalizar) {
      btnFinalizar.disabled = true;
      btnFinalizar.classList.add("opacity-50", "cursor-not-allowed");
      btnFinalizar.textContent = "⏳ Procesando...";
    }

    // ✅ Disparar evento para que QrScannerV2 muestre el resumen
    document.dispatchEvent(
      new CustomEvent("finalizar-asistencia", {
        detail: { sessionId },
      }),
    );
  });

    // ✅ Click en "Confirmar"
  btnConfirmarResumen?.addEventListener("click", () => {
    const btn = btnConfirmarResumen;

    if (btn.disabled) return;

    btn.disabled = true;
    btn.classList.add("opacity-50", "cursor-not-allowed");
    btn.textContent = "⏳ Procesando...";

    // ✅ Tipo correcto para el timeout
    let timeoutRespaldo: any = null;

    const restaurarBoton = () => {
      if (timeoutRespaldo) {
        clearTimeout(timeoutRespaldo);
        timeoutRespaldo = null;
      }
      btn.disabled = false;
      btn.classList.remove("opacity-50", "cursor-not-allowed");
      btn.textContent = "Confirmar";
    };

    // ✅ Mostrar confirmación
    toast.warning("⚠️ ¿Estás seguro de finalizar la asistencia?", {
      description:
        "Esta acción cerrará la sesión y no se podrán registrar más asistencias.",
      duration: 10000,
      cancel: {
        label: "❌ Cancelar",
        onClick: () => {
          restaurarBoton();
          toast.info("✅ Operación cancelada");
        },
      },
      action: {
        label: "✅ Sí, finalizar",
        onClick: async () => {
          try {
            const { error: cerrarError } = await supabase
              .from("v2_attendance_sessions")
              .update({
                status: "closed",
                closed_at: new Date().toISOString(),
              })
              .eq("id", sessionId);

            if (cerrarError) {
              console.error("Error cerrando sesión:", cerrarError);
              toast.error("❌ Error al finalizar la asistencia");
              restaurarBoton();
              return;
            }

            // ✅ Ocultar elementos
            const panelResumen = document.getElementById("panelResumen");
            const panelUltimoAlumno =
              document.getElementById("panelUltimoAlumno");
            const estado = document.getElementById("estado");
            const contador = document.getElementById("contador");
            const btnFinalizar = document.getElementById("btnFinalizar");
            const btnAsistenciaManual = document.getElementById(
              "btnAsistenciaManual",
            );

            if (panelResumen) panelResumen.style.display = "none";
            if (panelUltimoAlumno) panelUltimoAlumno.style.display = "none";
            if (estado) estado.style.display = "none";
            if (contador) contador.style.display = "none";
            if (btnFinalizar) btnFinalizar.style.display = "none";
            if (btnAsistenciaManual)
              btnAsistenciaManual.style.display = "none";

            const contenido = document.getElementById("contenidoResumen");
            if (contenido) {
              contenido.innerHTML = `
            <div class="text-green-600 font-bold text-xl text-center">
              ✅ Asistencia finalizada correctamente
            </div>
          `;
            }

            toast.success("✅ Asistencia finalizada correctamente");
          } catch (e) {
            console.error("Error Confirmar:", e);
            toast.error("❌ Error al finalizar la asistencia");
            restaurarBoton();
          }
        },
      },
      onDismiss: () => {
        restaurarBoton();
      },
    });

    // ✅ FORZAR restauración después del timeout
    timeoutRespaldo = setTimeout(() => {
      if (btn.disabled) {
        restaurarBoton();
      }
    }, 10500);
  });
</script>
