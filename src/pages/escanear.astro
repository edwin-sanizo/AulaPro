---
import Layout from "../layouts/Layout.astro";
import HeaderMinimal from "../components/HeaderMinimal.astro";
import QrScanner from "../components/QrScanner.astro";
---

<Layout title="Control de Asistencia">
  <HeaderMinimal />

  <div class="mt-6 text-center">
    <h2 class="text-2xl font-bold">Control de Asistencia</h2>

    <div id="contador" class="text-center font-semibold text-lg mt-4">
      Asistentes: 0
    </div>
  </div>

  <div class="mt-6">
    <!-- Aquí irá el lector QR -->
    <QrScanner />

    <div id="estado" class="mt-4 text-center">📷 Esperando QR...</div>

    <div
      id="panelResumen"
      class="hidden mt-6 p-4 bg-slate-100 rounded-xl"
    >
      <div id="contenidoResumen"></div>

      <button
        id="btnConfirmarResumen"
        class="w-full mt-4 bg-green-600 text-white py-3 rounded-xl cursor-pointer"
      >
        Confirmar
      </button>
    </div>

    <div
      id="panelUltimoAlumno"
      class="mt-4 p-4 bg-slate-100 rounded-lg text-center"
    >
      <div id="tituloUltimoAlumno" class="hidden font-semibold">
        Último alumno escaneado
      </div>
      <div id="ultimoAlumno">Ningún alumno escaneado</div>
    </div>

    <a
      href="/asistencia-manual"
      class="block w-full text-center bg-blue-600 hover:bg-blue-700 text-white font-semibold py-3 rounded-xl transition"
    >
      Asistencia manual
    </a>

    <button
      id="btnFinalizar"
      class="w-full mt-6 bg-red-600 hover:bg-red-700 text-white py-3 rounded-xl cursor-pointer"
    >
      Finalizar Asistencia
    </button>

    <button
      id="btnNuevaAsistencia"
      class="w-full mt-4 bg-green-600 hover:bg-green-700 text-white py-3 rounded-xl"
    >
      Nueva asistencia
    </button>

    <div class="mt-6">
      <a
        href="/"
        class="block w-full text-center bg-slate-600 hover:bg-slate-700 text-white py-3 rounded-xl"
      >
        Volver
      </a>
    </div>
  </div>
</Layout>

<script>
  import { supabase } from "../lib/supabase";
  import {getLocalDate, getLocalDateTime} from '../libr/fechas';

  const btnFinalizar = document.getElementById("btnFinalizar");

  const asistenciaCerrada =
  localStorage.getItem("asistenciaCerrada") === "true";

  (window as any).asistenciaCerrada = asistenciaCerrada;

  if (asistenciaCerrada) {
    document.addEventListener("DOMContentLoaded", () => {
      document.getElementById("btnFinalizar")?.remove();
      document.getElementById("panelResumen")?.remove();
      document.getElementById("estado")?.remove();
      document.getElementById("panelUltimoAlumno")?.remove();
      document.getElementById("contador")?.remove();

      const cont = document.getElementById("contador");
      if (cont) cont.textContent = "Asistencia cerrada";

      const manual = document.querySelector("a[href='/asistencia-manual']");
      if (manual) manual.remove();
    });
  }

  const btnNuevaAsistencia = document.getElementById("btnNuevaAsistencia");

  btnNuevaAsistencia?.addEventListener("click", async () => {
    try {
      // 1. Desbloquear sistema
      localStorage.removeItem("asistenciaCerrada");
      (window as any).asistenciaCerrada = false;

      // 2. Limpiar base de datos del día
      const hoy = getLocalDate();

      await supabase
        .from("attendance")
        .delete()
        .eq("fecha_dia", hoy);

      // 3. Reset UI
      const contador = document.getElementById("contador");
      if (contador) contador.textContent = "Asistentes: 0";

      const estado = document.getElementById("estado");
      if (estado) estado.textContent = "📷 Esperando QR...";

      const panelResumen = document.getElementById("panelResumen");
      if (panelResumen) panelResumen.classList.add("hidden");

      const resultado = document.getElementById("resultado");
      if (resultado) {
        resultado.innerHTML = "📷 Cámara iniciada. Apunte al código QR.";
      }

      // 4. Reiniciar cámara
      location.reload();     

    } catch (error) {
      console.error("Error reiniciando asistencia:", error);
    }
  });

  const btnConfirmarResumen = document.getElementById("btnConfirmarResumen");

  btnConfirmarResumen?.addEventListener("click", async() => {
    try {
      console.log("Confirmar click")
      // Para la tabla de attendance_historicos
      const hoy = getLocalDate();
  
      const { data, error } = await supabase
        .from("attendance")
        .select("*")
        .eq("fecha_dia", hoy);
  
      if(error) {
        console.error(error);
        return;
      }

      if (!data || data.length === 0) {
        console.log("No hay asistencia para guardar");
        return;
      }
      
      const {error: insertError} = await supabase.from("attendance_historicos").insert(
        data.map(item => ({
          student_codigo: item.student_codigo,
          estado: item.estado,
          fecha_dia: getLocalDate(),
          fecha_cierre: getLocalDateTime()
        }))
      );
  
      if(insertError) {
        console.error(insertError);
        return;
      }
  
      // esto antes de lo de arriba

      localStorage.setItem("asistenciaCerrada", "true");
      (window as any).asistenciaCerrada = true;

      const panelResumen = document.getElementById("panelResumen");
      const panelUltimoAlumno = document.getElementById("panelUltimoAlumno");
      const estado = document.getElementById("estado");
      const contador = document.getElementById("contador");
      const btnFinalizar = document.getElementById("btnFinalizar");

      (window as any).asistenciaCerrada = true;

      if (panelResumen) panelResumen.style.display = "none";
      if (panelUltimoAlumno) panelUltimoAlumno.style.display = "none";
      if (estado) estado.style.display = "none";
      if (contador) contador.style.display = "none";
      if (btnFinalizar) btnFinalizar.style.display = "none";

      if ((window as any).asistenciaCerrada) {
        document.getElementById("btnFinalizar")?.remove();
        document.getElementById("btnConfirmarResumen")?.remove();
        document.getElementById("panelResumen")?.remove();
      }

      if ((window as any).asistenciaCerrada) {
        btnFinalizar?.addEventListener("click", () => {
          alert("La asistencia ya fue cerrada");
        });
      }

      const contenido = document.getElementById("contenidoResumen");
      if (contenido) {
        contenido.innerHTML = `
          <div class="text-green-600 font-bold text-xl">
            ✅ Asistencia finalizada correctamente
          </div>
        `;
      }
    } catch(e) {
      console.error("Error Confirmar:", e);
    }
  });
</script>