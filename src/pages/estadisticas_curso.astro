---
import Layout from "../layouts/Layout.astro";
import HeaderMinimal from "../components/HeaderMinimal.astro";
import { createClient } from "../lib/supabase";

// 1️⃣ Obtener usuario del middleware
const user = Astro.locals.user;

// 2️⃣ Crear cliente para consultas en servidor
const supabase = createClient({
  request: Astro.request,
  cookies: Astro.cookies,
});

// 3️⃣ Obtener el ID de la asignación desde la URL
const url = new URL(Astro.url);
const teacherAssignmentId = url.searchParams.get('id');

// 4️⃣ Si no hay ID, redirigir a selección
if (!teacherAssignmentId) {
  return Astro.redirect('/seleccion?error=sin-asignacion');
}

const { data: profesor } = await supabase
  .from("v2_teachers")
  .select(`
    id,
    first_name,
    last_name
  `)
  .eq("auth_user_id", user?.id)
  .single();

// 5️⃣ Obtener datos de la asignación, materia y curso
const { data: asignacion } = await supabase
  .from("v2_teacher_assignments")
  .select(`
    id,
    course_id,
    v2_courses (
      level,
      parallel
    ),
    v2_subjects (
      name
    )
  `)
  .eq("id", teacherAssignmentId)
  .eq("teacher_id", profesor?.id)
  .single();

// 6️⃣ Si no existe la asignación, redirigir
if (!asignacion) {
  return Astro.redirect('/dashboard?error=sin-permiso');
}

// 7️⃣ Extraer datos (v2_courses y v2_subjects vienen como objetos)
const subject = asignacion.v2_subjects as any;
const course = asignacion.v2_courses as any;
const subjectName = subject?.name || 'Sin materia';
const courseName = `${course?.level || ''} ${course?.parallel || ''}`.trim() || 'Sin curso';

// 8️⃣ Obtener estudiantes del curso
const { data: estudiantes } = await supabase
  .from("v2_students")
  .select(`
    id,
    first_name,
    last_name
  `)
  .eq("course_id", asignacion.course_id);

// 9️⃣ Obtener sesiones del curso
const { data: sesiones } = await supabase
  .from("v2_attendance_sessions")
  .select("id")
  .eq("teacher_assignment_id", teacherAssignmentId);

const sessionIds = sesiones?.map(s => s.id) || [];

// 🔟 Obtener todas las asistencias de las sesiones
const { data: todasLasAsistencias } = await supabase
  .from("v2_attendance")
  .select(`
    student_id,
    status,
    session_id
  `)
  .in("session_id", sessionIds);

// 1️⃣1️⃣ Calcular estadísticas en el servidor
const totalEstudiantes = estudiantes?.length || 0;
const totalSesiones = sesiones?.length || 0;
const totalAsistencias = todasLasAsistencias?.length || 0;
const totalPosible = totalEstudiantes * totalSesiones;

const promedioGeneral = totalPosible > 0
  ? Math.round((totalAsistencias / totalPosible) * 100)
  : 0;

// 1️⃣2️⃣ Calcular ranking por estudiante
const ranking = [];

for (const estudiante of estudiantes || []) {
  const asistenciasEstudiante = todasLasAsistencias?.filter(
    a => a.student_id === estudiante.id
  ) || [];

  const totalAsistenciasEstudiante = asistenciasEstudiante.length;
  const retrasosEstudiante = asistenciasEstudiante.filter(
    a => a.status === "Retraso"
  ).length;
  const ausenciasEstudiante = totalSesiones - totalAsistenciasEstudiante;

  const porcentajeEstudiante = totalSesiones > 0
    ? Math.round((totalAsistenciasEstudiante / totalSesiones) * 100)
    : 0;

  ranking.push({
    nombre: `${estudiante.first_name} ${estudiante.last_name}`,
    porcentaje: porcentajeEstudiante,
    ausencias: ausenciasEstudiante,
    retrasos: retrasosEstudiante,
    asistencias: totalAsistenciasEstudiante,
  });
}

// 1️⃣3️⃣ Ordenar ranking por porcentaje (mejor a peor)
ranking.sort((a, b) => b.porcentaje - a.porcentaje);

// 1️⃣4️⃣ Encontrar mejores y peores
const mejorAsistencia = ranking[0] || null;
const masAusencias = [...ranking].sort((a, b) => b.ausencias - a.ausencias)[0] || null;
const masRetrasos = [...ranking].sort((a, b) => b.retrasos - a.retrasos)[0] || null;

// 1️⃣5️⃣ Calcular estadísticas adicionales
const presentes = todasLasAsistencias?.filter(a => a.status === "Presente").length || 0;
const retrasos = todasLasAsistencias?.filter(a => a.status === "Retraso").length || 0;
const licencias = todasLasAsistencias?.filter(a => a.status === "Licencia").length || 0;

// 1️⃣6️⃣ Pasar datos al cliente
const initialData = {
  teacherAssignmentId,
  subject: subjectName,
  course: courseName,
  estudiantes: estudiantes || [],
  ranking,
  totalEstudiantes,
  totalSesiones,
  totalAsistencias,
  promedioGeneral,
  mejorAsistencia,
  masAusencias,
  masRetrasos,
  presentes,
  retrasos,
  licencias,
};
---

<Layout title="Estadísticas del Curso">
  <HeaderMinimal />

  <div class="max-w-2xl mx-auto p-6">
    <!-- Migas de pan -->
    <nav class="text-sm text-gray-500 mb-4">
      <a href="/dashboard" class="hover:text-slate-700">Dashboard</a>
      <span class="mx-2">›</span>
      <a href="/seleccion" class="hover:text-slate-700">Selección</a>
      <span class="mx-2">›</span>
      <a href="/administracion" class="hover:text-slate-700">Administración</a>
      <span class="mx-2">›</span>
      <a href="/seleccionar_reportes" class="hover:text-slate-700">Reportes</a>
      <span class="mx-2">›</span>
      <span class="text-slate-800 font-medium">Estadísticas del Curso</span>
    </nav>

    <!-- ✅ Información del curso (desde el servidor) -->
    <div class="mt-2">
      <div class="text-3xl font-bold text-center">
        {subjectName}
      </div>
      <div class="text-gray-500 text-center">
        {courseName}
      </div>
    </div>

    <!-- ✅ Estadísticas (desde el servidor) -->
    <div id="estadisticas" class="mt-6 p-4 bg-slate-100 rounded-xl">
      <h3 class="font-bold text-lg mb-4">📊 Estadísticas Generales</h3>

      <div>👥 Total estudiantes: {totalEstudiantes}</div>
      <div class="mt-2">📅 Días con asistencia registrada: {totalSesiones}</div>
      <div class="mt-2 font-bold text-blue-600">📈 Promedio general de asistencia: {promedioGeneral}%</div>

      <div class="mt-4">
        🏆 Mejor asistencia:
        <strong>{mejorAsistencia?.nombre || 'N/A'}</strong>
        {mejorAsistencia ? `(${mejorAsistencia.porcentaje}%)` : ''}
      </div>

      <div class="mt-2">
        ⚠️ Más ausencias:
        <strong>{masAusencias?.nombre || 'N/A'}</strong>
        {masAusencias ? `(${masAusencias.ausencias})` : ''}
      </div>

      <div class="mt-2">
        🕒 Más retrasos:
        <strong>{masRetrasos?.nombre || 'N/A'}</strong>
        {masRetrasos ? `(${masRetrasos.retrasos})` : ''}
      </div>

      <hr class="my-4">

      <h3 class="font-bold text-lg mb-4">📋 Detalle por Estudiante</h3>

      {ranking.length > 0 ? (
        <div class="space-y-2">
          {ranking.map((estudiante: any, index: number) => (
            <div class="border-b py-2">
              <div class="flex justify-between items-center">
                <span>
                  <strong>{index + 1}.</strong> {estudiante.nombre}
                </span>
                <span class="font-semibold">{estudiante.porcentaje}%</span>
              </div>
              <div class="text-sm text-gray-500 flex gap-4 mt-1">
                <span>✅ Asistencias: {estudiante.asistencias}</span>
                <span>🕒 Retrasos: {estudiante.retrasos}</span>
                <span>❌ Ausencias: {estudiante.ausencias}</span>
              </div>
            </div>
          ))}
        </div>
      ) : (
        <div class="text-gray-500">No hay datos disponibles</div>
      )}
    </div>

    <div class="mt-6">
      <a
        href={`/seleccionar_reportes?id=${teacherAssignmentId}`}
        class="block w-full text-center bg-slate-600 hover:bg-slate-700 text-white py-3 rounded-xl transition-colors"
      >
        ← Volver
      </a>
    </div>
  </div>
</Layout>