---
import Header from "../components/Header.astro";
import HeroCard from "../components/HeroCard.astro";
import Layout from "../layouts/Layout.astro";
import { createClient } from "../lib/supabase";
import { getLocalDate } from "../libr/fechas";

const user = Astro.locals.user;

const supabase = createClient({
  request: Astro.request,
  cookies: Astro.cookies,
});

const url = new URL(Astro.url);
const teacherAssignmentId = url.searchParams.get('id');

if (!teacherAssignmentId) {
  return Astro.redirect('/seleccion?error=sin-asignacion');
}

const { data: profesor } = await supabase
  .from("v2_teachers")
  .select("id")
  .eq("auth_user_id", user?.id)
  .single();

// ✅ Usar as any para evitar errores de TypeScript
const { data: asignacion } = await supabase
  .from("v2_teacher_assignments")
  .select(`
    id,
    v2_courses (
      id,
      level,
      parallel
    ),
    v2_subjects (
      name
    )
  `)
  .eq("id", teacherAssignmentId)
  .eq("teacher_id", profesor?.id)
  .single();

if (!asignacion) {
  return Astro.redirect('/seleccion?error=asignacion-no-encontrada');
}

// ✅ Acceder con as any para que TypeScript no se queje
const subject = asignacion.v2_subjects as any;
const course = asignacion.v2_courses as any;
const subjectName = subject?.name || 'Sin materia';
const courseName = `${course?.level || ''} ${course?.parallel || ''}`.trim() || 'Sin curso';

const hoy = getLocalDate();
const { data: sesionExistente } = await supabase
  .from("v2_attendance_sessions")
  .select("*")
  .eq("teacher_assignment_id", teacherAssignmentId)
  .eq("session_date", hoy)
  .maybeSingle();

const sesionAbierta = sesionExistente?.status === "open";
const sesionCerrada = sesionExistente?.status === "closed";
const sessionId = sesionExistente?.id || null;
---

<Layout title="Gestión">
  <Header />

  <div class="max-w-2xl mx-auto p-6">
    <nav class="text-sm text-gray-500 mb-4">
      <a href="/dashboard" class="hover:text-slate-700">Dashboard</a>
      <span class="mx-2">›</span>
      <a href="/seleccion" class="hover:text-slate-700">Selección</a>
      <span class="mx-2">›</span>
      <span class="text-slate-800 font-medium">Gestión</span>
    </nav>

      
      <div class="mt-6">
        <div class="text-3xl font-bold text-center">{subjectName}</div>
        <div class="text-gray-500 text-center">{courseName}</div>
      </div>

      <div class="mt-4">
        <HeroCard />
      </div>

      <div class="mt-8 space-y-3">
        <!-- ✅ Formulario que envía a /api/llamar_lista -->
        <form method="POST" action="/api/llamar_lista">
          <input type="hidden" name="teacherAssignmentId" value={teacherAssignmentId} />
          
          {sesionCerrada ? (
            <button
              type="button"
              disabled
              class="w-full bg-gray-400 text-white p-3 rounded-xl cursor-not-allowed"
            >
              ⛔ Asistencia finalizada hoy
            </button>
          ) : sesionAbierta ? (
            <button
              type="submit"
              class="w-full bg-yellow-600 hover:bg-yellow-700 text-white p-3 rounded-xl transition-colors cursor-pointer"
            >
              🔄 Continuar sesión abierta
            </button>
          ) : (
            <button
              type="submit"
              class="w-full bg-green-600 hover:bg-green-700 text-white p-3 rounded-xl transition-colors cursor-pointer"
            >
              📋 Llamar Lista
            </button>
          )}
        </form>

        <button
          id="revisarTarea"
          class="w-full bg-blue-600 hover:bg-blue-700 text-white p-3 rounded-xl transition-colors cursor-pointer"
        >
          ✅ Revisar Tareas
        </button>

        <a
          href={`/seleccion?id=${teacherAssignmentId}`}
          class="block text-center bg-slate-600 hover:bg-slate-700 text-white p-3 rounded-xl transition-colors"
        >
          ← Volver
        </a>
      </div>

      {sesionCerrada && (
        <div class="mt-4 p-3 bg-red-100 text-red-700 rounded-xl text-center">
          ⚠️ La asistencia de hoy ya fue finalizada
        </div>
      )}
    
  </div>
</Layout>

<script>
  import { toast } from 'sonner';

  document.getElementById('revisarTarea')?.addEventListener('click', () => {
  toast.info('📝 Revisión de tareas - Próximamente', {
    duration: 3000,
  });
});
</script>