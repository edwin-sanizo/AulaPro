---
import LayoutCarnets from "../layouts/LayoutCarnets.astro";
import escudocolegio from "../../public/escudocolegio.webp";
import { supabase } from "../lib/supabase";

import QRCode from "qrcode";

const { data: students, error } = await supabase.from("students").select("*");

if (error) {
  console.error(error);
}

const studentsWithQR = await Promise.all(
  (students ?? []).map(async (s) => {
    const qr = await QRCode.toDataURL(s.codigo);
    return { ...s, qr };
  }),
);
---

<LayoutCarnets>
  <h1 class="text-3xl font-bold text-center mb-6">Carnets de Estudiantes</h1>

  <div class="flex justify-center mb-6">
    <div>
      <button
        onclick="window.print()"
        class="bg-blue-600 text-white px-4 py-3 rounded-xl hover:bg-blue-700 cursor-pointer"
      >
        Imprimir Carnets
      </button>
      <div class="mt-6">
        <a
          href="/administracion"
          class="block w-full text-center bg-slate-600 hover:bg-slate-700 text-white py-3 rounded-xl"
        >
          Volver
        </a>
      </div>
    </div>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 ml-5">
    {
      studentsWithQR.map((student) => (
        <div class="carnet bg-white rounded-xl shadow-lg border border-slate-200 p-4">
          <div class="text-center">
            <img
              src={escudocolegio.src}
              alt="Escudo del Colegio"
              class="w-16 h-16 mx-auto"
            />

            <h2 class="font-bold mt-2 uppercase">feppa san calixto</h2>
          </div>

          <hr class="my-3" />

          <div class="text-center mt-3">
            <p class="text-xs text-slate-500 uppercase">estudiante</p>
            <h3 class="text-lg font-bold mt-2">{student.nombre_completo}</h3>
          </div>

          <div class="mt-4 text-center text-sm">
            <p>
              {student.nivel} {student.paralelo}
            </p>

            <p class="mt-4">
              <strong>Código:</strong>
              {student.codigo}
            </p>
          </div>

          <div class="flex justify-center mt-4">
            <img src={student.qr} alt="Código QR" class="w-36 h-36" />
          </div>
        </div>
      ))
    }
  </div>
</LayoutCarnets>

<style>
@media print {
  @page {
    size: letter;
    margin: 10mm;
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 10px;
  }

  .carnet {
    break-inside: avoid;
    page-break-inside: avoid;
  }

  img {
    max-width: 100%;
    height: auto;
    object-fit: contain;
  }

  button, a {
    display: none;
  }
}
</style>
