---
import Layout from "../layouts/Layout.astro";
import HeaderMinimal from "../components/HeaderMinimal.astro";
---

<Layout title="Asistencia Manual">
    <HeaderMinimal />

    <h2 class="text-2xl font-bold text-center mt-6">Asistencia Manual</h2>

    <input
        type="text"
        id="buscador"
        placeholder="Buscar estudiante..."
        class="w-full mt-4 p-3 border rounded-xl"
    />

    <div id="listaEstudiantes" class="mt-6 space-y-2">Cargando...</div>

    <div class="mt-6">
        <a
            href="/escanear"
            class="block w-full text-center bg-slate-600 text-white py-3 rounded-xl"
        >
            Atrás
        </a>
    </div>
</Layout>

<script>
    import { supabase } from "../lib/supabase";

    import {getLocalDate} from '../libr/fechas';

    if (localStorage.getItem("asistenciaCerrada") === "true") {
        document.body.innerHTML = `
            <div class="max-w-md mx-auto mt-10 bg-white shadow-lg rounded-xl p-6 text-center">

                <h2 class="text-green-600 font-bold text-2xl">
                    ✅ Asistencia finalizada
                </h2>

                <p class="text-gray-600 mt-2">
                    El registro de asistencia del día ha sido cerrado correctamente.
                </p>

                <div class="mt-4 text-sm text-gray-700">
                    ✔ Registro guardado en base de datos<br/>
                    ✔ QR desactivado<br/>
                    ✔ Asistencia manual bloqueada
                </div>

                <a href="/"
                class="inline-block mt-6 px-6 py-3 bg-slate-600 text-white rounded-xl">
                    Volver al inicio
                </a>

            </div>
        `;

        throw new Error("Asistencia cerrada");
    }   

    const listaEstudiantes = document.getElementById("listaEstudiantes");

    let todosLosEstudiantes: {
        codigo: string;
        nombre_completo: string;
    }[] = [];
    
    const estadosHoy = new Map<string, string>();

    async function cargarEstudiantes() {
        const { data: students } = await supabase
            .from("students")
            .select("codigo, nombre_completo")
            .order("nombre_completo");

        const hoy = getLocalDate();

        const { data: asistenciasHoy } = await supabase
            .from("attendance")
            .select("student_codigo, estado")
            .eq("fecha_dia", hoy);

        estadosHoy.clear();

        asistenciasHoy?.forEach((a) => {
            estadosHoy.set(a.student_codigo, a.estado);
        });

        if (!listaEstudiantes || !students) return;

        todosLosEstudiantes = students;

        mostrarEstudiantes(students);
    }

    (window as any).registrarEstado = async (
        codigo: string,
        estado: string,
        btn: HTMLButtonElement,
    ) => {
        const hoy = getLocalDate();

        const { data: existente } = await supabase
            .from("attendance")
            .select("id")
            .eq("student_codigo", codigo)
            .eq("fecha_dia", hoy)
            .maybeSingle();

        if (existente) {
            return;
        }

        const { error } = await supabase.from("attendance").insert([
            {
                student_codigo: codigo,
                fecha_dia: hoy,
                estado: estado
            },
        ]);

        if (error) {
            console.log(error);
            return;
        }

        estadosHoy.set(codigo, estado);
        mostrarEstudiantes(todosLosEstudiantes);

    };
    
    function mostrarEstudiantes(
        estudiantes: {
            codigo: string;
            nombre_completo: string;
        }[],
    ) {
    if (!listaEstudiantes) return;

        listaEstudiantes.innerHTML = estudiantes
            .map((s) => {
                const estado = estadosHoy.get(s.codigo)
                const registrado = !!estado;

                return `
        <div class="flex justify-between items-center ${
            registrado ? "bg-green-100" : "bg-slate-100"
        } p-3 rounded-lg">
        <div>
            <div class="font-semibold">${s.nombre_completo}</div>
            <div class="text-sm text-gray-500">${s.codigo}</div>
        </div>

        ${
            registrado
                ? `
                <button
                class="bg-gray-400 text-white px-3 py-1 rounded-lg"
                disabled
                >
                ✔ ${estado}
                </button>
            `
                : `
                <div class="flex gap-1">
                    <button
                        class="bg-green-600 text-white px-2 py-1 rounded-lg text-sm"
                        onclick="registrarEstado('${s.codigo}', 'Presente', this)"
                    >
                        Presente
                    </button>

                    <button
                        class="bg-yellow-500 text-white px-2 py-1 rounded-lg text-sm"
                        onclick="registrarEstado('${s.codigo}', 'Retraso', this)"
                    >
                        Retraso
                    </button>

                    <button
                        class="bg-blue-600 text-white px-2 py-1 rounded-lg text-sm"
                        onclick="registrarEstado('${s.codigo}', 'Licencia', this)"
                    >
                        Licencia
                    </button>
                </div>
            `
        }
        </div>
    `;
    })
    .join("");
    }

    cargarEstudiantes();

    const buscador = document.getElementById("buscador");

    buscador?.addEventListener("input", (e) => {
        const texto = (e.target as HTMLInputElement).value.toLowerCase();

        const filtrados = todosLosEstudiantes.filter(
            (s) =>
                s.nombre_completo.toLowerCase().includes(texto) ||
                s.codigo.toLowerCase().includes(texto),
        );

        mostrarEstudiantes(filtrados);
    });
</script>