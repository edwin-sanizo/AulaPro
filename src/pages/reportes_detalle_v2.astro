---
import Layout from "../layouts/Layout.astro";
import HeaderMinimal from "../components/HeaderMinimal.astro";
import { createClient } from "../lib/supabase";

// 1️⃣ Obtener usuario del middleware
const user = Astro.locals.user;

// 2️⃣ Crear cliente para consultas en servidor
const supabase = createClient({
  request: Astro.request,
  cookies: Astro.cookies,
});

// 3️⃣ Obtener parámetros desde la URL
const url = new URL(Astro.url);
const sessionId = url.searchParams.get('sessionId');
const teacherAssignmentId = url.searchParams.get('assignmentId');

// 4️⃣ Si faltan parámetros, redirigir a reportes
if (!sessionId || !teacherAssignmentId) {
  return Astro.redirect('/reportes_v2?error=sin-datos');
}

const { data: profesor } = await supabase
  .from("v2_teachers")
  .select(`
    id,
    first_name,
    last_name
  `)
  .eq("auth_user_id", user?.id)
  .single();

// 5️⃣ Obtener asignación para saber el course_id
const { data: asignacion } = await supabase
  .from("v2_teacher_assignments")
  .select(`
    id,
    course_id
  `)
  .eq("id", teacherAssignmentId)
  .eq("teacher_id", profesor?.id)
  .single();

if (!asignacion) {
  return Astro.redirect('/dashboard?error=sin-permiso');
}

// 6️⃣ Obtener estudiantes del curso
const { data: estudiantes } = await supabase
  .from("v2_students")
  .select("*")
  .eq("course_id", asignacion.course_id)
  .order("last_name");

// 7️⃣ Obtener asistencias de la sesión
const { data: asistencias } = await supabase
  .from("v2_attendance")
  .select("*")
  .eq("session_id", sessionId);

// 8️⃣ Crear un mapa de estados para acceso rápido
const estadosMap: Record<string, string> = {};
asistencias?.forEach((a: any) => {
  estadosMap[a.student_id] = a.status;
});

// 9️⃣ Obtener materia y curso para mostrar en el título
const { data: asignacionData } = await supabase
  .from("v2_teacher_assignments")
  .select(`
    v2_courses (
      level,
      parallel
    ),
    v2_subjects (
      name
    )
  `)
  .eq("id", teacherAssignmentId)
  .single();

const subject = asignacionData?.v2_subjects as any;
const course = asignacionData?.v2_courses as any;
const subjectName = subject?.name || 'Sin materia';
const courseName = `${course?.level || ''} ${course?.parallel || ''}`.trim() || 'Sin curso';
---

<Layout title="Detalle de Asistencia">
  <HeaderMinimal />

  <div class="max-w-2xl mx-auto p-6">
    <!-- Migas de pan -->
    <nav class="text-sm text-gray-500 mb-4">
      <a href="/dashboard" class="hover:text-slate-700">Dashboard</a>
      <span class="mx-2">›</span>
      <a href="/seleccion" class="hover:text-slate-700">Selección</a>
      <span class="mx-2">›</span>
      <a href="/administracion" class="hover:text-slate-700">Administración</a>
      <span class="mx-2">›</span>
      <a href="/seleccionar_reportes" class="hover:text-slate-700">Reportes</a>
      <span class="mx-2">›</span>
      <a href="/reportes_v2" class="hover:text-slate-700">Reporte Diario</a>
      <span class="mx-2">›</span>
      <span class="text-slate-800 font-medium">Detalle</span>
    </nav>

    <!-- Info del curso -->
    <div class="mt-2">
      <div class="text-3xl font-bold text-center">{subjectName}</div>
      <div class="text-gray-500 text-center">{courseName}</div>
    </div>

    <!-- ✅ Lista de estudiantes con su estado (desde el servidor) -->
    <div id="detalle" class="mt-6 p-4 bg-slate-100 rounded-xl">
      {estudiantes && estudiantes.length > 0 ? (
        estudiantes.map((alumno: any, index: number) => {
          const estado = estadosMap[alumno.id] || 'Ausente';
          const estadoColor = estado === 'Presente' ? 'text-green-600' :
                              estado === 'Retraso' ? 'text-yellow-600' :
                              estado === 'Licencia' ? 'text-blue-600' :
                              'text-red-600';
          return (
            <div class="border-b py-2 flex justify-between items-center">
              <div>
                <strong>{index + 1}.</strong>
                {alumno.first_name} {alumno.last_name}
              </div>
              <div class={`text-sm font-semibold ${estadoColor}`}>
                {estado}
              </div>
            </div>
          );
        })
      ) : (
        <div class="text-center text-gray-500">
          No hay estudiantes registrados en este curso
        </div>
      )}
    </div>

    <div class="mt-6">
      <a
        href={`/reportes_v2?id=${teacherAssignmentId}`}
        class="block w-full text-center bg-slate-600 hover:bg-slate-700 text-white py-3 rounded-xl transition-colors"
      >
        ← Volver
      </a>
    </div>
  </div>
</Layout>