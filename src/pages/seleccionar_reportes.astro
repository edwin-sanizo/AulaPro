---
import Layout from "../layouts/Layout.astro";
import HeaderMinimal from "../components/HeaderMinimal.astro";
import { createClient } from "../lib/supabase";

const user = Astro.locals.user;

const supabase = createClient({
  request: Astro.request,
  cookies: Astro.cookies,
});

const url = new URL(Astro.url);
const teacherAssignmentId = url.searchParams.get('id');

if (!teacherAssignmentId) {
  return Astro.redirect('/seleccion?error=sin-asignacion');
}

const { data: profesor } = await supabase
  .from("v2_teachers")
  .select(`
    id,
    first_name,
    last_name
  `)
  .eq("auth_user_id", user?.id)
  .single();

const { data: asignacion } = await supabase
  .from("v2_teacher_assignments")
  .select(`
    id,
    v2_courses (
      id,
      level,
      parallel
    ),
    v2_subjects (
      name
    )
  `)
  .eq("id", teacherAssignmentId)
  .eq("teacher_id", profesor?.id)
  .single();

if (!asignacion) {
  return Astro.redirect('/dashboard?error=sin-permiso');
}

// ✅ CORREGIDO: Acceder al primer elemento del array
const subject = asignacion.v2_subjects as any;
const course = asignacion.v2_courses as any;
const subjectName = subject?.name || 'Sin materia';
const courseName = `${course?.level || ''} ${course?.parallel || ''}`.trim() || 'Sin curso';
const courseId = course?.[0]?.id || '';
---

<Layout title="Reportes">
  <HeaderMinimal />

  <div class="max-w-2xl mx-auto p-6">
    <nav class="text-sm text-gray-500 mb-4">
      <a href="/dashboard" class="hover:text-slate-700">Dashboard</a>
      <span class="mx-2">›</span>
      <a href="/seleccion" class="hover:text-slate-700">Selección</a>
      <span class="mx-2">›</span>
      <a href="/administracion" class="hover:text-slate-700">Administración</a>
      <span class="mx-2">›</span>
      <span class="text-slate-800 font-medium">Reportes</span>
    </nav>

    <div class="mt-2">
      <div class="text-3xl font-bold text-center">
        {subjectName}
      </div>
      <div class="text-gray-500 text-center">
        {courseName}
      </div>
    </div>

    <div class="mt-6 space-y-4">
      <a
        href={`/reportes_v2?id=${teacherAssignmentId}`}
        class="block bg-blue-600 hover:bg-blue-700 text-white text-center p-3 rounded-xl transition-all duration-200"
      >
        📅 Reporte Diario
      </a>

      <a
        href={`/historial_estudiante?id=${teacherAssignmentId}`}
        class="block bg-green-600 hover:bg-green-700 text-white text-center p-3 rounded-xl transition-all duration-200"
      >
        👨‍🎓 Historial por Estudiante
      </a>

      <a
        href={`/estadisticas_curso?id=${teacherAssignmentId}`}
        class="block bg-purple-600 hover:bg-purple-700 text-white text-center p-3 rounded-xl transition-all duration-200"
      >
        📈 Estadísticas del Curso
      </a>

      <a
        href={`/administracion?id=${teacherAssignmentId}`}
        class="block bg-slate-600 hover:bg-slate-700 text-white text-center p-3 rounded-xl transition-all duration-200"
      >
        ← Volver
      </a>
    </div>
  </div>
</Layout>