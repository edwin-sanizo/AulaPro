---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Button from "../components/Button.astro";
import { createClient } from "../lib/supabase";

// 1️⃣ Obtener usuario del middleware
const user = Astro.locals.user;

// 2️⃣ Crear cliente para consultas en servidor
const supabase = createClient({
  request: Astro.request,
  cookies: Astro.cookies,
});

// 3️⃣ Obtener el ID de la asignación desde la URL
const url = new URL(Astro.url);
const teacherAssignmentId = url.searchParams.get('id');

// 4️⃣ Si no hay ID, redirigir a selección
if (!teacherAssignmentId) {
  return Astro.redirect('/seleccion?error=sin-asignacion');
}

const { data: profesor } = await supabase
  .from("v2_teachers")
  .select(`
    id,
    first_name,
    last_name
  `)
  .eq("auth_user_id", user?.id)
  .single();

// 5️⃣ Obtener datos de la asignación, materia y curso
const { data: asignacion } = await supabase
  .from("v2_teacher_assignments")
  .select(`
    id,
    v2_courses (
      id,
      level,
      parallel
    ),
    v2_subjects (
      name
    )
  `)
  .eq("id", teacherAssignmentId)
  .eq("teacher_id", profesor?.id)
  .single();

// 6️⃣ Si no existe la asignación, redirigir
if (!asignacion) {
  return Astro.redirect('/dashboard?error=sin-permiso');
}

// 7️⃣ Extraer datos
const subject = asignacion.v2_subjects as any;
const course = asignacion.v2_courses as any;
const subjectName = subject?.name || 'Sin materia';
const courseName = `${course?.level || ''} ${course?.parallel || ''}`.trim() || 'Sin curso';
const courseId = course?.id || '';
---

<Layout title="Administración">
  <Header />

  <div class="max-w-2xl mx-auto p-6">
    <!-- Migas de pan -->
    <nav class="text-sm text-gray-500 mb-4">
      <a href="/dashboard" class="hover:text-slate-700">Dashboard</a>
      <span class="mx-2">›</span>
      <a href="/seleccion" class="hover:text-slate-700">Selección</a>
      <span class="mx-2">›</span>
      <span class="text-slate-800 font-medium">Administración</span>
    </nav>

    <div class="mt-2">
        <div class="text-3xl font-bold text-center">{subjectName}</div>
        <div class="text-gray-500 text-center">{courseName}</div>
    </div>

    <!-- ✅ Botón Generar Carnets con course_id desde el servidor -->
    <div class="mt-6">
        <a
            id="btnCarnets"
            href={`/generar_carnets?course_id=${courseId}`}
            class="block w-full text-center bg-blue-600 hover:bg-blue-700 text-white py-3 rounded-xl transition-colors"
        >
            📇 Generar carnets
        </a>
    </div>

    <!-- ✅ Botón Reportes de Asistencia -->
    <div class="mt-4">
        <a
            href={`/seleccionar_reportes?id=${teacherAssignmentId}`}
            class="block w-full text-center bg-emerald-600 hover:bg-emerald-700 text-white py-3 rounded-xl transition-colors"
        >
            📊 Reportes de Asistencia
        </a>
    </div>

    <!-- Volver -->
    <div class="mt-6">
        <a
            href={`/seleccion?id=${teacherAssignmentId}`}
            class="block w-full text-center bg-slate-600 hover:bg-slate-700 text-white py-3 rounded-xl transition-colors"
        >
            ← Volver
        </a>
    </div>
    
  </div>
</Layout>